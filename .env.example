# ClawLite .env example
#
# 1) Copy to .env
# 2) Fill only what you use
# 3) Never commit secrets to git

# Paths (optional)
# CLAWLITE_HOME=/home/user

# Gateway
# OPENCLAW-like style: token required when gateway is exposed
CLAWLITE_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Providers
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

# Web tools
# BRAVE_API_KEY=...

# Channels (fill only enabled ones)
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# WHATSAPP_TOKEN=...
