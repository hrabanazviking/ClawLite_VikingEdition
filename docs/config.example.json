{
  "workspace_path": "~/.clawlite/workspace",
  "agents": {
    "defaults": {
      "model": "gemini/gemini-2.5-flash",
      "max_tokens": 8192,
      "temperature": 0.1
    }
  },
  "providers": {
    "gemini":     { "api_key": "" },
    "openai":     { "api_key": "" },
    "anthropic":  { "api_key": "" },
    "openrouter": { "api_key": "" }
  },
  "gateway": {
    "host": "127.0.0.1",
    "port": 8787,
    "auth": {
      "mode": "off",
      "token": ""
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "",
      "allow_from": []
    },
    "discord": {
      "enabled": false,
      "token": "",
      "allow_from": []
    },
    "slack": {
      "enabled": false,
      "bot_token": "",
      "app_token": "",
      "allow_from": []
    }
  }
}
