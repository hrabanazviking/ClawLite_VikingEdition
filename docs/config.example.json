{
  "workspace_path": "/home/user/.clawlite/workspace",
  "state_path": "/home/user/.clawlite/state",
  "provider": {
    "model": "gemini/gemini-2.5-flash",
    "litellm_base_url": "https://api.openai.com/v1",
    "litellm_api_key": ""
  },
  "agents": {
    "defaults": {
      "model": "gemini/gemini-2.5-flash",
      "max_tokens": 8192,
      "temperature": 0.1,
      "max_tool_iterations": 40
    }
  },
  "gateway": {
    "host": "127.0.0.1",
    "port": 8787,
    "auth": {
      "mode": "off",
      "token": "",
      "allow_loopback_without_auth": true,
      "header_name": "Authorization",
      "query_param": "token",
      "protect_health": false
    },
    "diagnostics": {
      "enabled": true,
      "require_auth": true,
      "include_config": false
    },
    "heartbeat": {
      "enabled": true,
      "interval_s": 1800
    }
  },
  "scheduler": {
    "heartbeat_interval_seconds": 1800,
    "timezone": "UTC"
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "",
      "mode": "polling",
      "allow_from": [],
      "poll_interval_s": 1.0,
      "poll_timeout_s": 20,
      "reconnect_initial_s": 2.0,
      "reconnect_max_s": 30.0,
      "send_timeout_s": 15.0,
      "send_retry_attempts": 3,
      "send_backoff_base_s": 0.35,
      "send_backoff_max_s": 8.0,
      "send_backoff_jitter": 0.2,
      "send_circuit_failure_threshold": 1,
      "send_circuit_cooldown_s": 60.0
    }
  }
}
